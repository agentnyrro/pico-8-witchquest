--[[
tab 3 - witch code
--]]
function move_witch(w)
	--move x
	if w.noclip or (not collide_walls(w, w.dx, 0) and not collide_objects(w, w.dx, 0, 'torch'))  then
  w.x += w.dx
  w.hitbox.l += w.dx
  w.hitbox.r += w.dx
	elseif abs(w.dx) == w.speed then
 	w.dx /= w.speed
 	move_witch(w)
 end
 
	--move y
 if w.noclip or (not collide_walls(w, 0, w.dy) and not collide_objects(w, 0, w.dy, 'torch')) then
   w.y += w.dy
   w.hitbox.t += w.dy
   w.hitbox.b += w.dy
 elseif abs(w.dy) == w.speed then
 	w.dy /= w.speed
 	move_witch(w)
 end
 
 w.dx = 0
 w.dy = 0
end

function draw_witch(w)
 spr(w.k,w.x,w.y,
  	w.w, w.h, w.flip_x)
end


function recalc_w_hitbox()
 witch.hitbox.l = witch.x + 2
 witch.hitbox.r = witch.x + 8*witch.w - 1 -2
 witch.hitbox.t = witch.y + 3
 witch.hitbox.b = witch.y + 8*witch.h - 1
end

-- player movement
function upd_witch(w)
	-- if detected unexpected collision
	if collide_objects(w, 0, 0, '*') or collide_walls(w, 0, 0) then
		w.noclip = true
	elseif w.noclip then
		w.noclip = false
	end
	
	
	if (btn(left)) then
		w.dx = -w.speed
  w.flip_x = false
  w.k = 64 --64 --1
 end
  
 if (btn(right)) then
  w.dx = w.speed
  w.flip_x = true
  w.k = 64 --64 --1
 end
 
 if (btn(up)) then
  w.dy = -w.speed
 	w.flip_x = false
 	w.k = 66 --66 --2
 end
 
 if (btn(down)) then
	 w.dy = w.speed
 	w.flip_x = false
 	w.k = 68 --68 --3
 end
 
 move_witch(w)
end
