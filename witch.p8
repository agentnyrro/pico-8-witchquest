pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--[[
tab 0 - general game flow
--]]
function _init()
	left,right,up,down = 0,1,2,3
	
	objects = {}
	
	score = 0
	game_active=false
 game_over = false

 tics_tr = -1 --used for timing round transitions
	tics_round_time = 30*20 --round time; starts at 20s	
 round = 0

	witch = new_object(64, --spr -- face left
										55, 55, -- x, y
										0, 0, -- dx, dy
										2, -- speed
										2, 2, -- width, height
										'witch', --kind
										upd_witch, draw_witch) 
	witch.flip_x = false
 witch.hitbox.l += 2
 witch.hitbox.r -= 2
 witch.hitbox.t += 3
 witch.lay_draw = 1 --above everything else
	witch.noclip = false -- used for handling unexpected collisions e.g. after teleport
	add(objects, witch) 
end

-- debug func
function print_status() 
 print('dx:'..witch.dx,12)
 print('dy:'..witch.dy,0,10,12)
 print('x:'..witch.x,0,20,12)
 print('y:'..witch.y,0,30,12)
end

function _update()
 for o in all(objects) do
		o:upd_fun(o)
	end

	-- game start/restart
	if btnp(❎) then
		game_active = not game_active
		if game_active then

			if game_over then
	   game_over = false
	   score = 0
  	end
   
  	tics_round_time = 30*20
   round = 1
			spawn_torches(5)
		else
			_init()
		end
	end

	if game_active then
		local all_torches_lit = true
		for o in all(objects) do
			if o.kind == 'torch' and o.k == 5 then
				all_torches_lit = false
				break
			end
		end

		if all_torches_lit then
   if tics_tr == -1 then
    tics_tr = 5 -- transition should take 5 frames
   elseif tics_tr > 0 then 
    tics_tr -= 1
   else
    spawn_torches(5)
    tics_tr = -1
    tics_round_time = 30*max(20-round, 5)
    round += 1
   end
		end

  tics_round_time -= 1
  if tics_round_time == 0 then
   game_over = true
   game_active = false
   clear_obj('torch')
  end
	end
end



function _draw()
  map()
		
		rectfill(14, 0, 127-14, 6, 1)
		if not game_active then
			print('press ❎ to start game!', 19, 1,9)
		else
			print('press ❎ to restart!', 25, 1,9)
  end

		rectfill(10, 121, 117, 127, 1)
  print("press z to light torches!", 15, 122,9)
  --print_status()
  for i = 0, 1 do
   for o in all(objects) do
    if (o.lay_draw == i) then
     o:draw_fun(o)
    end
   end
  end
  
  print("score: "..score, 9, 9, 9)
		print(flr(tics_round_time/30), 110, 9, 8)
  if game_over then
   rectfill(10, 50, 117, 77, 1)
   print("game over", 46, 60, 9)
  end

  camera(flr(witch.x/128)*128,
  							flr(witch.y/128)*128)
end
